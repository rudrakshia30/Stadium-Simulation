# CrowdSphere AI — Server Environment Variables
# Copy this file to .env and fill in your values

# ─── Required for production ───────────────────────────────────────────────
# JWT secret — use at least 32 random characters in production
JWT_SECRET=change-me-in-production-use-32-plus-chars

# Operations access code — shared secret for the OCC login
OPS_ACCESS_CODE=crowdsphere-demo-2026

# ─── Gemini AI (optional — app works without it in demo fixture mode) ───────
GEMINI_API_KEY=

# Gemini model to use (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ─── Server configuration ──────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ─── CORS origin ───────────────────────────────────────────────────────────
# Must match the frontend origin exactly
CLIENT_ORIGIN=http://localhost:5173
